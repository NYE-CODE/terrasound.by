# Скопируйте на сервер: cp deploy/deploy.env.example deploy/deploy.env
# Этот файл НЕ коммитьте с секретами (deploy/deploy.env в .gitignore).

# --- Пути и git ---
APP_DIR=/var/www/terrasound.by
GIT_BRANCH=main
GIT_REMOTE=origin

# --- Python backend ---
PYTHON=python3
VENV_DIR=.venv
# Имя systemd-сервиса API (см. deploy/terrasound-api.service.example)
API_SERVICE=terrasound-api
API_USER=www-data
API_GROUP=www-data
API_HOST=127.0.0.1
API_PORT=8000

# --- Node / pnpm ---
PNPM=pnpm
# Полный путь, если pnpm не в PATH (например /usr/local/bin/pnpm)
# PNPM=/root/.local/share/pnpm/pnpm
# frozen-lockfile = воспроизводимая установка на сервере
PNPM_INSTALL_FLAGS=--frozen-lockfile

# --- Сборка frontend (Vite) ---
# Public API URL baked into JS. Same domain (recommended):
VITE_API_URL=https://terrasound.by

# Admin: оставьте пустым — запросы идут на admin.terrasound.by/api/ (nginx → backend), без CORS.
# Если задать URL, админка будет ходить на другой домен (нужен CORS на backend).
ADMIN_VITE_API_URL=
VITE_SITE_URL=https://terrasound.by
# Prerender при build ходит в API за списком товаров/блога.
# Обычно локальный API после restart, до сборки frontend.
PRERENDER_API_URL=http://127.0.0.1:8000

# Собирать статику (frontend + admin)
BUILD_FRONTEND=true
BUILD_ADMIN=true

# --- Nginx (опционально) ---
NGINX_RELOAD=true
# sudo без пароля для systemctl/nginx — настройте visudo при необходимости
SUDO=sudo

# --- Поведение ---
# Ждать /api/health после перезапуска API (секунды)
HEALTH_TIMEOUT=30
# Не перезапускать API (только pull + deps + migrate + build)
SKIP_API_RESTART=false

# --- backend/.env ---
# Секреты (SECRET_KEY, ADMIN_PASSWORD, DATABASE_URL, CORS_ORIGINS, ENVIRONMENT)
# храните в backend/.env — скрипт его НЕ перезаписывает.
# При первом деплое: cp backend/.env.example backend/.env && nano backend/.env
